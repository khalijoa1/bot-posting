# Copy to .env and fill in real values. Never commit .env.

# From @BotFather
BOT_TOKEN=123456:your-bot-token

# Comma-separated Telegram numeric user ids allowed to control this bot.
# Get your own id by messaging @userinfobot.
ALLOWED_USER_IDS=123456789

DATABASE_URL=sqlite+aiosqlite:///./poster.db

# --- Optional: repost-from-source-channel feature (Telethon userbot) ---
# Leave these blank to disable the feature entirely. Get API id/hash from
# https://my.telegram.org -> API Development Tools.
TELETHON_API_ID=
TELETHON_API_HASH=
TELETHON_PHONE=
# Run `python scripts/telethon_login.py` locally once to generate this.
TELETHON_SESSION_STRING=
